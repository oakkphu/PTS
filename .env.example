# คัดลอกเป็น .env แล้วกรอกค่าจริง (อย่า commit ไฟล์ .env)

# —— เซิร์ฟเวอร์ ——
PORT=3000
HOST=0.0.0.0
SESSION_SECRET=เปลี่ยนเป็นสตริงสุ่มยาวๆ
# ถ้าอยู่หลัง HTTPS reverse proxy:
# TRUST_PROXY=1
# COOKIE_SECURE=true
APP_BASE_URL=http://localhost:3000

# —— SQL Server ——
DB_USER=uinet
DB_PASSWORD=
DB_SERVER=tvsdb2.thanvasupos.com
DB_PORT=28914
DB_NAME=BD_PTS
# DB_ENCRYPT=true
# DB_TRUST_CERT=true

# —— Email OTP (Google Workspace / Gmail App Password) ——
MAIL_MODE=smtp
MAIL_FROM_NAME=PTS Learning
MAIL_FROM_EMAIL=businessdev@thanvasu.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=businessdev@thanvasu.com
SMTP_PASS=

# หรือใช้ Brevo แทน
# BREVO_API_KEY=xkeysib-xxxxxxxx

# —— Google Calendar (แจ้งเตือนวันเรียน) ——
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# —— PromptPay (ถ้ามี) ——
# PROMPTPAY_ID=

# —— Docker Hub image name (ใช้กับ docker compose) ——
# DOCKER_IMAGE=YOUR_DOCKERHUB_USER/pts-learning:latest
# HOST_PORT=3000
